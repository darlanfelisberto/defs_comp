<?xml version="1.0" encoding="UTF-8"?>
<facelet-taglib xmlns="http://java.sun.com/xml/ns/javaee"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="http://java.sun.com/xml/ns/javaee https://java.sun.com/xml/ns/javaee/web-facelettaglibrary_2_0.xsd"
                version="2.0">

    <description>defs JSF tag library.</description>

    <namespace>br.com.feliva.defs</namespace>

    <tag>
        <tag-name>output</tag-name>
        <component>
            <component-type>defs.output</component-type>
        </component>
        <attribute>
            <name>value</name>
            <required>true</required>
            <type>java.lang.String</type>
        </attribute>
    </tag>

    <tag>
        <tag-name>DOutPut</tag-name>
        <component>
            <component-type>br.com.feliva.defs.components.DOutPut</component-type>
            <renderer-type>br.com.feliva.defs.components.DOutPutRenderer</renderer-type>
        </component>
        <attribute>
            <name>rendered</name>
            <required>false</required>
            <type>java.lang.Boolean</type>
        </attribute>
    </tag>

    <tag>
        <tag-name>Kanban</tag-name>
        <component>
            <component-type>br.com.feliva.component.kamban</component-type>
            <renderer-type>br.com.feliva.defs.components.kambanRenderer</renderer-type>
        </component>
        <attribute>
            <name>model</name>
            <required>false</required>
            <type>java.util.List</type>
        </attribute>
        <attribute>
            <name>rendered</name>
            <required>false</required>
            <type>java.lang.Boolean</type>
        </attribute>
        <attribute>
            <name>id</name>
            <required>false</required>
            <type>java.lang.String</type>
        </attribute>
    </tag>
</facelet-taglib>